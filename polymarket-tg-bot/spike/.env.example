# =====================================================================
#  TRADE SPIKE — uses REAL funds on Polygon mainnet. Read spike/README.md first.
#  Use a DEDICATED wallet with a small amount. NEVER commit this file.
# =====================================================================

# Owner EOA private key (0x-prefixed). This key controls your deposit wallet.
# Use a throwaway wallet funded with a few dollars of pUSD — not your main wallet.
PRIVATE_KEY=

# Builder / Relayer API credentials (one set, used for relayer auth).
# Generate at https://polymarket.com/settings?tab=api-keys  (or the Builder tab).
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# Your builder code (bytes32, 0x...). From https://polymarket.com/settings?tab=builder
# This is what attributes the trade's volume to you.
BUILDER_CODE=

# The outcome token to trade. Get a market's clobTokenIds from the Gamma API
# (the browsing bot already surfaces these) and paste ONE outcome's token id here.
TOKEN_ID=

# How much to spend on the test BUY, in USD. Keep it tiny.
SIZE_USD=1

# Polygon RPC endpoint (used only to read your pUSD balance).
RPC_URL=https://polygon-rpc.com

# Safety switch. The `trade` stage refuses to run unless this is exactly: yes
CONFIRM=no
