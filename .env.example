# --- Telegram ---
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# --- Polymarket ---
# Public market-data API (no key needed). Leave as-is unless Polymarket changes it.
GAMMA_API_BASE=https://gamma-api.polymarket.com

# Your builder code (bytes32, starts with 0x). Get it at:
# https://polymarket.com/settings?tab=builder
# Phase 1 (browsing) does NOT use this. It's wired in now so Phase 2 (trading) can attribute orders to you.
BUILDER_CODE=

# How many markets to show per "trending" page.
PAGE_SIZE=6
